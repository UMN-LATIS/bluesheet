{
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/UMN-LATIS/laravel-shibboleth"
    },
    {
      "type": "composer",
      "url": "https://nova.laravel.com"
    }
  ],
  "name": "laravel/laravel",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "fakerphp/faker": "^1.23",
    "guzzlehttp/guzzle": "^7.8",
    "lab404/laravel-impersonate": "^1.7.4",
    "laracasts/cypress": "^3.0",
    "laravel/framework": "^13.0",
    "laravel/mcp": "^0.5.0",
    "laravel/nova": "^5.8",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^3.0",
    "orangehill/iseed": "^3.0",
    "owen-it/laravel-auditing": "^14.0",
    "razorbacks/laravel-shibboleth": "dev-umn",
    "sentry/sentry-laravel": "^4.25",
    "spatie/laravel-permission": "^6.0"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.2",
    "barryvdh/laravel-ide-helper": "^3.6",
    "deployer/deployer": "^7.1",
    "filp/whoops": "^2.15",
    "laravel/nova-devtool": "^1.8",
    "laravel/sail": "^1.26",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.0",
    "pestphp/pest": "^4",
    "pestphp/pest-plugin-laravel": "^4"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true,
      "pestphp/pest-plugin": true
    },
    "platform": {
      "php": "8.4"
    }
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/",
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  }
}
